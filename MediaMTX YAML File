# MediaMTX Configuration - Clean Version
# To parse down the massive YAML file that comes with the standard repo for MediaMTX, use this clean version instead for secure Tailscale streams:
# Use nano mediamtx.yaml, then Ctrl+K to cut the contents of the entire YAML file. Paste this code, then Ctrl+O to write out, enter, then Ctrl+X to exit
# If you change the username and password, make sure to restart the MediaMTX service for the changes to take effect!

logLevel: info
rtspAddress: :8554

# Internal Authentication for Local Publishing
authMethod: internal
authInternalUsers:
  - user: YOURUSERNAME
    pass: YOURPASSWORD
    permissions:
      - action: publish
        path: cam
      - action: read
        path: cam

# Path Configuration for USB Camera
paths:
  cam:
    # Launches ffmpeg on initialization to pull from local USB V4L2 device
    runOnInit: ffmpeg -f v4l2 -i /dev/video0 -f rtsp rtsp://YOURUSERNAME:YOURPASSWORD>
    runOnInitRestart: yes

#To view the stream, use VLC player and open Network Stream rtsp://YOURUSERNAME:YOURPASSWORD@YOURSERVERIP:8554/cam
#I use Tailscale to make sure that no one can see this stream except for myself
#If ./mediamtx results in errors not being able to open /dev/video0, then "video" needs to be added to user groups.
# Add the current user to the video subsystem group using this command:
# sudo usermod -aG video $USER

# Log out and log back in for the group policy changes to take effect (if headless ssh, then exit -> ssh again), then verify with this command:
# groups
